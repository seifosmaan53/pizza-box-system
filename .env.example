# ============================================================
# PIZZA BOX INVENTORY & INVOICING SYSTEM — ENVIRONMENT VARS
# ============================================================
# Copy this file to .env and fill in ALL values before running.
#
# SECURITY NOTES:
# - NEVER commit .env to git (it's in .gitignore)
# - Use strong, unique secrets for production
# - Rotate secrets regularly (at least quarterly)
# ============================================================

# ------ Database ------
# PostgreSQL connection string
# Production: use a strong password (32+ chars, mixed case + numbers + symbols)
POSTGRES_PASSWORD=CHANGE_ME_use_a_strong_password
DATABASE_URL=postgresql://postgres:CHANGE_ME_use_a_strong_password@localhost:5432/pizzabox

# ------ Redis ------
REDIS_HOST=localhost
REDIS_PORT=6379
# Required in production — generate with: openssl rand -base64 32
REDIS_PASSWORD=CHANGE_ME_redis_password

# ------ JWT ------
# CRITICAL: Generate unique secrets for each environment
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# These MUST be different from each other and at least 64 characters
JWT_SECRET=CHANGE_ME_run_the_command_above
JWT_REFRESH_SECRET=CHANGE_ME_run_the_command_above_again

# ------ Server ------
PORT=3001
# MUST be 'production' in production deployments
NODE_ENV=development
LOG_LEVEL=info

# ------ CORS ------
# URL of the frontend (no trailing slash)
# Production: use your actual domain (e.g. https://app.pizzaboxco.com)
CLIENT_URL=http://localhost:5173

# ------ Invoice ------
# Prefix used in invoice numbers (e.g. INV → INV-2026-00001)
INVOICE_PREFIX=INV

# ------ AI (Anthropic) — Optional ------
# Get your key at https://console.anthropic.com
# Leave empty to disable AI features
ANTHROPIC_API_KEY=

# ------ Email (Nodemailer) — Optional ------
# Used for password reset emails. Falls back to console logging if not set.
# For Gmail: use App Password (not your account password)
#   https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=noreply@pizzaboxco.com

# ------ Frontend (Vite) ------
# These must be prefixed with VITE_ to be exposed to the browser
# Production: use your actual API URL (e.g. https://api.pizzaboxco.com/api)
VITE_API_URL=http://localhost:3001/api
VITE_APP_NAME=Pizza Box Manager
